{
  "name": "myapp",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "nodemon ./src/bin/www",
    "start:prod": "NODE_ENV=production node ./src/bin/www",
    "debug": "node --inspect ./src/bin/www",
    "clean": "rm -rf ./data ./src/data ./node_modules ./test-data",
    "test": "cross-env NODE_ENV=test jest --forceExit"
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "debug": "4.4.3",
    "ejs": "^3.1.10",
    "express": "~5.2.1",
    "express-ejs-layouts": "^2.5.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
