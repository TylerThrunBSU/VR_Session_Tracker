<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | VR Session Tracker</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
  <link rel="stylesheet" href="/stylesheets/style.css" />
</head>
<body class="d-flex flex-column min-vh-100">

  <header>
    <nav class="navbar navbar-expand-lg vr-navbar">
      <div class="container">
        <a class="navbar-brand vr-brand" href="/">VR SESSION TRACKER</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link vr-nav-link <%= currentPage === 'home' ? 'active' : '' %>" href="/">HOME</a>
            </li>
            <li class="nav-item">
              <a class="nav-link vr-nav-link <%= currentPage === 'log' ? 'active' : '' %>" href="/sessions/new">LOG SESSION</a>
            </li>
            <li class="nav-item">
              <a class="nav-link vr-nav-link <%= currentPage === 'history' ? 'active' : '' %>" href="/sessions">HISTORY</a>
            </li>
            <li class="nav-item">
              <a class="nav-link vr-nav-link <%= currentPage === 'stats' ? 'active' : '' %>" href="/stats">STATS</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <main class="container py-4 flex-grow-1">
    <%- body %>
  </main>

  <footer class="vr-footer mt-auto">
    <div class="container py-3 text-center">
      <span class="vr-footer-text">VR SESSION TRACKER</span>
      <span class="vr-footer-sep"> &mdash; </span>
      <span class="vr-footer-sub">CS 408 &bull; Spring 2026 &bull; Tyler Thrun</span>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/javascripts/myscript.js"></script>
</body>
</html>
