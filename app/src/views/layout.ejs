<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | VR Session Tracker</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/stylesheets/style.css" />
</head>
<body class="d-flex flex-column min-vh-100">

  <header>
    <nav class="navbar navbar-expand-md navbar-vr sticky-top">
      <div class="container">
        <a class="navbar-brand nav-brand" href="/">
          <i class="bi bi-headset me-2"></i>VR TRACKER
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
          <i class="bi bi-list text-neon" style="font-size:1.4rem;"></i>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link <%= currentPage === 'home' ? 'active' : '' %>" href="/">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= currentPage === 'log' ? 'active' : '' %>" href="/sessions/new">Log Session</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= currentPage === 'history' ? 'active' : '' %>" href="/sessions">History</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= currentPage === 'stats' ? 'active' : '' %>" href="/stats">Stats</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <main class="container py-4 flex-grow-1">
    <%- body %>
  </main>

  <footer class="vr-footer mt-auto">
    <div class="container py-3 text-center">
      <small class="text-muted-custom">VR Session Tracker &mdash; CS 408 &bull; Spring 2026 &bull; Tyler Thrun</small>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/javascripts/myscript.js"></script>
</body>
</html>
