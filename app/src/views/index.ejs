<!-- Hero -->
<div class="text-center fade-up" style="padding: 4rem 0 2.5rem;">
  <div style="font-size: 3.5rem; margin-bottom: 1rem;">
    <i class="bi bi-headset text-neon"></i>
  </div>
  <h1 style="font-size: 2.2rem;" class="mb-3">
    VR <span class="text-neon">Session</span> Tracker
  </h1>
  <p class="text-muted-custom" style="max-width: 480px; margin: 0 auto 2rem; font-size: 1rem; line-height: 1.6;">
    Track your virtual reality sessions and analyze your play history.
  </p>
  <div class="d-flex justify-content-center gap-3 flex-wrap">
    <a href="/sessions/new" class="btn btn-neon">
      <i class="bi bi-plus-lg me-1"></i> Log a Session
    </a>
    <a href="/sessions" class="btn btn-outline-neon">
      <i class="bi bi-clock-history me-1"></i> View History
    </a>
  </div>
</div>

<!-- Total Sessions Stat -->
<div class="row justify-content-center mb-4">
  <div class="col-sm-6 col-md-4 fade-up">
    <div class="glass-card text-center">
      <div class="stat-value"><%= total %></div>
      <div class="stat-label">Total Sessions Logged</div>
    </div>
  </div>
</div>
