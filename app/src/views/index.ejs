<div class="text-center py-5">
  <div class="vr-hero mb-4">
    <h1 class="vr-title">VR SESSION TRACKER</h1>
    <p class="vr-subtitle">Track your virtual reality sessions and analyze your play history.</p>
  </div>

  <div class="row justify-content-center mb-5">
    <div class="col-md-4">
      <div class="vr-stat-card">
        <div class="vr-stat-label">TOTAL SESSIONS LOGGED</div>
        <div class="vr-stat-value"><%= total %></div>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-center gap-3">
    <a href="/sessions/new" class="btn vr-btn-primary">LOG A SESSION</a>
    <a href="/sessions" class="btn vr-btn-outline">VIEW HISTORY</a>
  </div>
</div>
