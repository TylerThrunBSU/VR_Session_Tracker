#!/usr/bin/env bash
# Bash completion for dev.sh

_dev_sh_completions() {
  local cur="${COMP_WORDS[COMP_CWORD]}"
  local commands="env e new n login l docker dk ec2 ec init i up u down d build b push p deploy y logs lg web w open-web ow ssh s all a clean c nuke x help h"
  COMPREPLY=($(compgen -W "${commands}" -- "${cur}"))
}

complete -F _dev_sh_completions dev.sh
complete -F _dev_sh_completions ./dev.sh
